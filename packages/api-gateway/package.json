{
  "name": "@aoa/api-gateway",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "bun run src/server.ts",
    "build": "bun build src/index.ts --outdir dist --target bun && tsc --emitDeclarationOnly",
