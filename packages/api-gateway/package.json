    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "*",
    "bun-types": "latest"
  },
  "dependencies": {
    "hono": "4.12.7",
    "@aoa/kya": "workspace:*",
    "@aoa/policy": "workspace:*",
    "@aoa/risk": "workspace:*",
    "@aoa/settlement": "workspace:*",
    "@aoa/ledger": "workspace:*",
    "@aoa/compliance": "workspace:*"
  }
}
